# ============================================
# SUPABASE CONFIGURATION
# WARNING: DO NOT commit .env.local to git
# ============================================

# Public (Safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# PRIVATE - SERVER ONLY (Never expose to frontend)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# AI & EXTERNAL SERVICES
# WARNING: These are PRIVATE - server-only
# ============================================

# Google Gemini API Key (Server-side only)
GEMINI_API_KEY=your-gemini-api-key

# ============================================
# PAYMENT & APP CONFIG
# ============================================

NEXT_PUBLIC_UPI_ID=yourname@upi
NEXT_PUBLIC_UPI_NAME=Your Name
NEXT_PUBLIC_APP_URL=http://localhost:3000
